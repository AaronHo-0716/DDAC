# URL of your ASP.NET backend API (server-side only — never sent to the browser).
# In Docker this is overridden by docker-compose.yml to use the internal service name.
# For local dev without Docker, point to your locally running ASP.NET server.
API_URL=yourbackendapiurl

# Optional: used by admin credential preview to resolve object keys into displayable image URLs.
# Example localstack values:
# NEXT_PUBLIC_STORAGE_PUBLIC_BASE_URL=http://localhost:4566
# NEXT_PUBLIC_STORAGE_BUCKET_NAME=neighbourhelp-media
NEXT_PUBLIC_STORAGE_PUBLIC_BASE_URL=
NEXT_PUBLIC_STORAGE_BUCKET_NAME=
